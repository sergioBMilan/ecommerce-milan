# Configuración de pnpm para Milán Ecommerce
# Estas opciones reducen el riesgo de ataques de cadena de suministro npm.

# Cuarentena: solo instala paquetes publicados hace al menos 7 días (10080 minutos).
# Mitiga ataques tipo Shai-Hulud / Axios donde paquetes maliciosos son detectados
# y removidos del registro en cuestión de horas.
minimum-release-age=10080

# Resuelve peer dependencies automáticamente sin advertencias.
# Estándar en proyectos Next.js modernos.
auto-install-peers=true

# Refuerza que el lockfile sea consistente con package.json.
# Si alguien cambia una versión en package.json sin actualizar el lock, falla.
strict-peer-dependencies=false
